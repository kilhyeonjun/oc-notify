#!/usr/bin/env bash
# oc-notify — Smart notification wrapper for opencode-notifier
# https://github.com/kilhyeonjun/oc-notify
set -euo pipefail

CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/oc-notify/config"
[[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"

EVENT="${1:-unknown}"
MESSAGE="${2:-}"
SESSION_TITLE="${3:-}"
PROJECT_NAME="${4:-}"
TIMESTAMP="$(date +%H:%M:%S)"

[[ -z "$MESSAGE" ]] && exit 1

TITLE="OpenCode"
[[ -n "$PROJECT_NAME" ]] && TITLE="OpenCode ($PROJECT_NAME)"

SUBTITLE="$SESSION_TITLE"
[[ -z "$SUBTITLE" ]] && SUBTITLE="[$EVENT] $TIMESTAMP"

BODY="$MESSAGE — [$EVENT] $TIMESTAMP"

LOG_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/oc-notify"
mkdir -p "$LOG_DIR"
echo "$TIMESTAMP|$EVENT|$PROJECT_NAME|$SESSION_TITLE|$MESSAGE" >> "$LOG_DIR/history.log"

DND=$(defaults read com.apple.controlcenter "NSStatusItem Visible FocusModes" 2>/dev/null || echo "0")
if [[ "$DND" == "1" ]]; then
  FOCUS_MODE=$(plutil -extract data.0.modeIdentifier raw ~/Library/DoNotDisturb/DB/ModeConfigurations.json 2>/dev/null || echo "")
  if [[ -n "$FOCUS_MODE" ]]; then
    exit 0
  fi
fi

SWIFT_APP="$HOME/Applications/OcNotify.app/Contents/MacOS/oc-notify-swift"
if [[ -x "$SWIFT_APP" ]]; then
  FRONTMOST_BUNDLE=$(osascript -e 'tell application "System Events" to get bundle identifier of first process whose frontmost is true' 2>/dev/null || true)
  OC_NOTIFY_FRONTMOST_BUNDLE="$FRONTMOST_BUNDLE" "$SWIFT_APP" "$EVENT" "$MESSAGE" "$SESSION_TITLE" "$PROJECT_NAME" &
else
  osascript -e "display notification \"$BODY\" with title \"$TITLE\" subtitle \"$SUBTITLE\""
fi
